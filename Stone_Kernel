import numpy as np
import datetime

class StoneManifold:
    """Represents a 300-unit virtual transistor bank (M, T, or F)."""
    def __init__(self, name):
        self.name = name
        self.bank = np.full(300, 0.5)  # Initialize at Equilibrium (State n)

    def manifest(self, p1, p0, pn):
        """Dopes the manifold with trinary states (1, 0, n)."""
        if (p1 + p0 + pn) != 300:
            raise ValueError(f"Bank {self.name} must total 300 units.")
        
        # Create the trinary distribution array
        states = np.array(([1.0] * p1) + ([0.5] * pn) + ([0.0] * p0))
        delta = np.sum(self.bank != states)
        self.bank = states
        return delta

class SuccessionalProcessor:
    """The Master Engine executing Stone's Law: M * T * F = S."""
    def __init__(self):
        self.M = StoneManifold("Mass")
        self.T = StoneManifold("Time")
        self.F = StoneManifold("Field")
        self.audit_log = []

    def pulse(self, m_cfg, t_cfg, f_cfg):
        """Executes a single successional logic cycle."""
        # Update banks and record physical position deltas
        dM = self.M.manifest(*m_cfg)
        dT = self.T.manifest(*t_cfg)
        dF = self.F.manifest(*f_cfg)
        total_deltas = dM + dT + dF

        # Calculate Intensity (S) via Stone's Law
        # Mean of each bank represents its potential
        S = np.mean(self.M.bank) * np.mean(self.T.bank) * np.mean(self.F.bank)
        
        # Calculate Coherence (C): Logical overlap of active states
        # In a stable Riemann proof, the Field (F) must remain at 0.5 (n)
        active_overlap = np.logical_and(
            np.logical_and(self.M.bank > 0, self.T.bank > 0), 
            self.F.bank > 0
        )
        C = np.sum(active_overlap) / 300

        result = {
            "timestamp": datetime.datetime.now().isoformat(),
            "intensity_S": round(S, 6),
            "coherence_C": round(C, 4),
            "deltas": total_deltas
        }
        
        self.audit_log.append(result)
        return result

